# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment variables — never commit secrets
.env
.env.*
!.env.example

# Browser "Save Page As" dumps (e.g. Page Name_files/)
*_files/

# Image optimization working files (never commit).
# Convention: do all image optimization inside /image-work/ so artifacts can
# never be committed by accident. Optimized images belong in Supabase Storage,
# not the repo.
/image-work/
/*.webp
/*.png
/*.jpg
/*.jpeg
/*.heic
/*.HEIC
