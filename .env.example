# Stripe — get from https://dashboard.stripe.com/test/apikeys
# Publishable key is safe to expose in frontend code
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Shared secret for calling internal admin-only edge functions
# (e.g. send-review-request). Set the same value in Supabase secrets as INTERNAL_API_KEY.
VITE_INTERNAL_API_KEY=
